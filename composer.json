{
    "name": "danielhuntr/forms-plus",
    "description": "A drag-and-drop form builder for Statamic",
    "type": "statamic-addon",
    "require": {
        "php": "^8.3",
        "statamic/cms": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\FormsPlus\\": "src/"
        }
    },
    "extra": {
        "statamic": {
            "name": "Forms Plus",
            "slug": "forms-plus",
            "description": "A drag-and-drop form builder for Statamic"
        },
        "laravel": {
            "providers": [
                "App\\FormsPlus\\ServiceProvider"
            ]
        }
    }
}
